# VoiceBillRecord — 环境变量模板（可提交仓库）
#
# 使用：复制为 .env（勿提交 .env）
#   cp .env.example .env
# 仅在「运行 Serverless / 本地 API」的机器或进程里加载；静态前端构建不要注入下列密钥。

# ------------------------------------------------------------------
# 仅服务端（Neon / Vercel Functions / 本地 node）
# ------------------------------------------------------------------

# Neon Postgres 连接串（仅此一处；禁止写进前端 HTML/JS）
# 占位示例，请换成控制台提供的真实 URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-example.neon.tech/neondb?sslmode=require

# 大模型 HTTP（仅 /api/parse 等代理路由读取）
# 若用 OpenAI 兼容网关，可二选一或按你的厂商文档命名
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=replace-with-server-secret-never-in-browser

# 可选：模型名（若代理需要）
# LLM_MODEL=gpt-4o-mini

# ------------------------------------------------------------------
# HTTP 与安全边界
# ------------------------------------------------------------------

# 浏览器可访问的前端源（CORS）；生产填真实域名，多个用逗号需代码侧支持或只填主域
CORS_ORIGIN=http://localhost:3000

# 可选：保护写库/读库 API 的简单网关口令（Authorization: Bearer …）
# 若启用：须视为「可泄露的低权限口令」，定期轮换；更稳妥是同域 Cookie + Session（后续再做）
# API_GATE_TOKEN=replace-with-long-random-string

# ------------------------------------------------------------------
# 运行环境
# ------------------------------------------------------------------

NODE_ENV=development
